# Producción: SECRET_KEY segura (generar con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1

# Railway setea DATABASE_URL automáticamente al añadir PostgreSQL
# DATABASE_URL=postgres://...
